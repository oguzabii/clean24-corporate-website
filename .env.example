# Clean24 — contact form email delivery (Resend)
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must never be committed.

# Resend API key — create at https://resend.com (Dashboard > API Keys).
RESEND_API_KEY=

# Verified sender. The domain must be verified in Resend before sending.
# Format: "Display Name <address@domain>".
CONTACT_FROM_EMAIL="Clean24 Website <no-reply@clean-24.ch>"

# Recipient of contact requests. Optional — defaults to info@clean-24.ch.
CONTACT_TO_EMAIL=info@clean-24.ch
