# Clean24 shop — environment contract (placeholders only, never real keys).
# Copy to `.env.local` for local development; `.env*` files are gitignored
# (only this `.env.example` is tracked).
#
# STRIPE_SECRET_KEY       server-only. NEVER expose to the client, never log.
#                         Use TEST-mode keys (sk_test_...) during development.
# STRIPE_WEBHOOK_SECRET   server-only. Signing secret for the Stripe webhook
#                         endpoint (whsec_...). Test via `stripe listen`.
# NEXT_PUBLIC_SITE_URL    public. Base URL used to build the Stripe Checkout
#                         success/cancel redirect URLs.
#
# SUPABASE_URL            server-only here (order persistence). URL of the
#                         shop's OWN Supabase project — never point this at
#                         the Lead Autopilot / Sales Engine project.
# SUPABASE_SERVICE_ROLE_KEY
#                         server-only. Service-role key BYPASSES RLS — it must
#                         never get a NEXT_PUBLIC_ prefix, never reach the
#                         browser, never be logged.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
